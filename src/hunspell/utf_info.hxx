// Unicode character encoding information.
//
// Two-stage page table covering the BMP. To look up codepoint c:
//
//   utf_pages[utf_page_index[c >> 8]][c & 0xFF]
//
// cupper / clower are 0 when the codepoint has no case mapping; the
// caller substitutes the input codepoint in that case.

struct unicode_info {
  bool cletter;
  unsigned short cupper;
  unsigned short clower;
};

