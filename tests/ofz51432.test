#!/bin/sh
DIR="$(dirname "$0")"
HUNSPELL="${HUNSPELL:-$DIR/../src/tools/hunspell}"
LIBTOOL="${LIBTOOL:-$DIR/../libtool}"
out=$(echo "  " | $LIBTOOL --mode=execute "$HUNSPELL" -d "$DIR/ofz51432" -a 2>&1)
rc=$?
if [ $rc -ne 0 ]; then
    echo "FAIL: ofz51432 crashed with exit code $rc"
    exit 1
fi
echo "PASS: ofz51432"
exit 0
