#!/bin/sh
# gh#175: a suggestion that contains a space must not carry a part the speller
# rejects. Here "tv-" and "-tv" carry KEEPCASE, so a split suggestion like
# "Tv- word" is invalid (the "Tv-" part breaks keepcase) while "word -tv" is
# fine. The filter used to skip every space-containing suggestion, so the
# invalid ones lived. Each space-separated part of every suggestion returned
# here must pass the spell check.

DIR="$(dirname "$0")"
SRCDIR="$(cd "$DIR" && pwd)"
TOOLS="$SRCDIR/../src/tools"
HUNSPELL="${HUNSPELL:-$TOOLS/hunspell}"
LIBTOOL="${LIBTOOL:-$DIR/../libtool}"
RUN="$LIBTOOL --mode=execute $HUNSPELL -d $SRCDIR/gh175"

sugs=$(printf 'TV-word\nword-TV\nTV-word-TV\n' | $RUN -a 2>/dev/null \
    | sed -n 's/^&[^:]*: //p' | tr ',' '\n' | sed 's/^ *//;s/ *$//' | grep .)

# For each suggestion, check every whitespace-separated part on its own.
fails=$(printf '%s\n' "$sugs" | while IFS= read -r s; do
    [ -n "$s" ] || continue
    for part in $s; do
        verdict=$(printf '%s\n' "$part" | $RUN 2>/dev/null | grep '^[-+*&#]')
        case "$verdict" in
            "&"*|"#"*)
                echo "suggestion '$s' has a misspelled part '$part': $verdict"
                ;;
        esac
    done
done)

if [ -n "$fails" ]; then
    echo "FAIL: gh175"
    echo "$fails"
    exit 1
fi
echo "PASS: gh175"
exit 0
