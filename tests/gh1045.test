#!/bin/sh
# gh#1045: a mixed-case dictionary word must not stop a different word from
# being spell checked. The dictionary holds "Lima/E" and the mixed-case
# "LiM/H". For "Lima" the loader adds a hidden all-uppercase-only stem "Lim".
# Checking "Limu" (from "Lima" through the -u suffix) used to strip through
# the H suffix to that hidden "Lim" stem first, and because an initial-capital
# query may not match an all-uppercase-only stem the whole check gave up
# instead of trying the valid "Lima" path. So "Limu" was rejected. It must be
# accepted.

DIR="$(dirname "$0")"
SRCDIR="$(cd "$DIR" && pwd)"
TOOLS="$SRCDIR/../src/tools"
HUNSPELL="${HUNSPELL:-$TOOLS/hunspell}"
LIBTOOL="${LIBTOOL:-$DIR/../libtool}"

got=$(printf 'Limu\n' | $LIBTOOL --mode=execute "$HUNSPELL" -d "$SRCDIR/gh1045" 2>/dev/null | grep '^[-+*&#]')
case "$got" in
    "+ Lima"|"*")
        echo "PASS: gh1045"
        exit 0
        ;;
esac
echo "FAIL: gh1045 check Limu: want it accepted, got '$got'"
exit 1
